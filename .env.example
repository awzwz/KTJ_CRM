# === Database ===
POSTGRES_USER=ktzh_user
POSTGRES_PASSWORD=ktzh_secret_password
POSTGRES_DB=ktzh_crm
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://ktzh_user:ktzh_secret_password@postgres:5432/ktzh_crm

# === Redis ===
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# === RabbitMQ ===
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=ktzh
RABBITMQ_PASSWORD=ktzh_rabbit_password
RABBITMQ_URL=amqp://ktzh:ktzh_rabbit_password@rabbitmq:5672/

# === Auth / JWT ===
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# === LLM ===
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o

# === Wazzup ===
WAZZUP_API_KEY=your-wazzup-api-key
WAZZUP_WEBHOOK_SECRET=your-wazzup-webhook-secret
WAZZUP_API_URL=https://api.wazzup24.com/v3
# UUID канала WhatsApp в Wazzup (подставьте свой; если вебхук не шлёт channelId — бот использует это)
WAZZUP_CHANNEL_ID=

# === Services Ports ===
GATEWAY_PORT=8000
WEBHOOK_PORT=8001
BOT_PORT=8002
LLM_PORT=8003
CRM_PORT=8004
ROUTING_PORT=8005
ANALYTICS_PORT=8006
AUTH_PORT=8007
NOTIFICATION_PORT=8008

# === Frontend ===
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8008
